// ─────────────────────────────────────────────────────────────────────────────
// Ethred — Prisma Schema
// SRS Reference: Section 5.2 (SQL DDL Script)
// Database: PostgreSQL 16 + PostGIS
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums (SRS Section 5.2) ──────────────────────────────────────────────────

enum UserRole {
  BUYER
  SELLER
  AGENCY_ADMIN
  AGENCY_AGENT
  ADMIN

  @@map("user_role")
}

enum PropertyStatus {
  DRAFT
  PENDING
  APPROVED
  SUSPENDED
  ARCHIVED

  @@map("property_status")
}

enum PropertyCategory {
  HOUSE
  APARTMENT
  LAND
  COMMERCIAL
  OFFICE
  WAREHOUSE
  VACATION

  @@map("property_category")
}

enum TransactionType {
  SALE
  RENT

  @@map("transaction_type")
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT

  @@map("media_type")
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED

  @@map("payment_status")
}

// ─── Users Table (SRS Section 5.2) ───────────────────────────────────────────

model User {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email               String?   @unique @db.VarChar(255)
  phone_number        String    @unique @db.VarChar(20)
  password_hash       String    @db.VarChar(255)
  role                UserRole  @default(BUYER)
  is_phone_verified   Boolean   @default(false)
  is_identity_verified Boolean  @default(false)
  created_at          DateTime  @default(now()) @db.Timestamptz
  updated_at          DateTime  @updatedAt @db.Timestamptz

  // Relations
  profile             Profile?
  properties          Property[]         @relation("PropertyOwner")
  agency_admin        Agency[]           @relation("AgencyAdmin")
  agency_membership   AgencyEmployee?
  favorites           UserFavorite[]
  inquiries_sent      PropertyInquiry[]  @relation("BuyerInquiries")
  invoices            BillingInvoice[]
  audit_logs          AuditLog[]         @relation("AuditActor")

  @@map("users")
}

// ─── Profiles Table ───────────────────────────────────────────────────────────

model Profile {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id            String   @unique @db.Uuid
  full_name          String   @db.VarChar(150)
  avatar_url         String?  @db.VarChar(500)
  preferred_language String   @default("en") @db.VarChar(5)
  created_at         DateTime @default(now()) @db.Timestamptz

  user               User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// ─── Agencies Table ───────────────────────────────────────────────────────────

model Agency {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  admin_id             String   @db.Uuid
  agency_name          String   @unique @db.VarChar(200)
  logo_url             String?  @db.VarChar(500)
  business_license_url String   @db.VarChar(500)
  is_approved          Boolean  @default(false)
  created_at           DateTime @default(now()) @db.Timestamptz

  admin                User              @relation("AgencyAdmin", fields: [admin_id], references: [id], onDelete: Restrict)
  employees            AgencyEmployee[]
  properties           Property[]

  @@map("agencies")
}

// ─── Agency Employees Table ───────────────────────────────────────────────────

model AgencyEmployee {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agency_id     String   @db.Uuid
  user_id       String   @unique @db.Uuid
  assigned_role String   @default("AGENT") @db.VarChar(50)
  created_at    DateTime @default(now()) @db.Timestamptz

  agency         Agency  @relation(fields: [agency_id], references: [id], onDelete: Cascade)
  user           User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("agency_employees")
}

// ─── Properties Table (SRS Section 5.2 — PostGIS geography) ──────────────────

model Property {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  owner_id         String          @db.Uuid
  agency_id        String?         @db.Uuid
  title_en         String          @db.VarChar(255)
  title_am         String?         @db.VarChar(255)
  description_en   String          @db.Text
  description_am   String?         @db.Text
  price_etb        Decimal         @db.Decimal(15, 2)
  price_usd        Decimal?        @db.Decimal(15, 2)
  transaction_mode TransactionType @default(SALE)
  category         PropertyCategory @default(HOUSE)
  // geom_point is managed via raw PostGIS SQL (Prisma doesn't natively support geography type)
  region           String          @db.VarChar(100)
  city             String          @db.VarChar(100)
  sub_city         String          @db.VarChar(100)
  woreda           String          @db.VarChar(100)
  kebele           String?         @db.VarChar(100)
  nearest_landmark String?         @db.VarChar(255)
  bedrooms         Int             @default(0)
  bathrooms        Int             @default(0)
  area_sqm         Decimal         @db.Decimal(10, 2)
  status           PropertyStatus  @default(DRAFT)
  // Promotion fields (SRS Section 8.3)
  is_featured      Boolean         @default(false)
  featured_tier    String?         @db.VarChar(50)
  featured_until   DateTime?       @db.Timestamptz
  created_at       DateTime        @default(now()) @db.Timestamptz
  updated_at       DateTime        @updatedAt @db.Timestamptz

  // Relations
  owner            User               @relation("PropertyOwner", fields: [owner_id], references: [id], onDelete: Cascade)
  agency           Agency?            @relation(fields: [agency_id], references: [id], onDelete: SetNull)
  media            PropertyMedia[]
  amenities        PropertyAmenity[]
  inquiries        PropertyInquiry[]
  favorites        UserFavorite[]

  @@index([status])
  @@index([region, sub_city, city])
  @@index([category])
  @@index([price_etb])
  @@index([owner_id])
  @@index([is_featured])
  @@map("properties")
}

// ─── Property Media Table ─────────────────────────────────────────────────────

model PropertyMedia {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  property_id     String    @db.Uuid
  file_url        String    @db.VarChar(500)
  media_category  MediaType @default(IMAGE)
  sort_order      Int       @default(0)
  created_at      DateTime  @default(now()) @db.Timestamptz

  property        Property  @relation(fields: [property_id], references: [id], onDelete: Cascade)

  @@map("property_media")
}

// ─── Property Amenities Table ─────────────────────────────────────────────────

model PropertyAmenity {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  property_id  String   @db.Uuid
  amenity_name String   @db.VarChar(100)

  property     Property @relation(fields: [property_id], references: [id], onDelete: Cascade)

  @@unique([property_id, amenity_name])
  @@map("property_amenities")
}

// ─── Property Inquiries Table ─────────────────────────────────────────────────

model PropertyInquiry {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  property_id String   @db.Uuid
  buyer_id    String   @db.Uuid
  message     String   @db.Text
  status      String   @default("NEW") @db.VarChar(50)
  created_at  DateTime @default(now()) @db.Timestamptz

  property    Property @relation(fields: [property_id], references: [id], onDelete: Cascade)
  buyer       User     @relation("BuyerInquiries", fields: [buyer_id], references: [id], onDelete: Cascade)

  @@index([property_id])
  @@index([buyer_id])
  @@map("property_inquiries")
}

// ─── User Favorites Table ─────────────────────────────────────────────────────

model UserFavorite {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String   @db.Uuid
  property_id String   @db.Uuid
  created_at  DateTime @default(now()) @db.Timestamptz

  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  property    Property @relation(fields: [property_id], references: [id], onDelete: Cascade)

  @@unique([user_id, property_id])
  @@map("user_favorites")
}

// ─── Billing Invoices Table ───────────────────────────────────────────────────

model BillingInvoice {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String        @db.Uuid
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("ETB") @db.VarChar(10)
  tx_ref            String        @unique @db.VarChar(100)
  payment_processor String        @default("CHAPA") @db.VarChar(50)
  status            PaymentStatus @default(PENDING)
  metadata          Json?
  created_at        DateTime      @default(now()) @db.Timestamptz
  updated_at        DateTime      @updatedAt @db.Timestamptz

  user              User          @relation(fields: [user_id], references: [id], onDelete: Restrict)

  @@index([user_id])
  @@index([status])
  @@map("billing_invoices")
}

// ─── Audit Logs Table (SRS Section 3.13) ─────────────────────────────────────

model AuditLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actor_id     String?  @db.Uuid
  action       String   @db.VarChar(100)
  target_table String   @db.VarChar(100)
  target_id    String?  @db.Uuid
  old_values   Json?
  new_values   Json?
  created_at   DateTime @default(now()) @db.Timestamptz

  actor        User?    @relation("AuditActor", fields: [actor_id], references: [id], onDelete: SetNull)

  @@index([actor_id])
  @@index([action])
  @@index([target_table, target_id])
  @@map("audit_logs")
}
