# ─────────────────────────────────────────────────────
# ETHRED BACKEND — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
# ─────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
FRONTEND_URL=http://localhost:3000

# ── Database (PostgreSQL + PostGIS via Docker) ────────
DATABASE_URL="postgresql://ethred_user:ethred_pass@localhost:5432/ethred_db?schema=public"

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d
JWT_COOKIE_NAME=ethred_token

# ── Google OAuth 2.0 ─────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# ── Email (OTP + Transactional Emails) ───────────────
# For Gmail: enable 2FA, then create an App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM="Ethred <noreply@ethred.com>"

# ── OTP ───────────────────────────────────────────────
OTP_EXPIRES_MINUTES=5

# ── File Uploads (Local Disk) ─────────────────────────
UPLOAD_DIR=uploads
MAX_IMAGE_SIZE_MB=10
MAX_DOC_SIZE_MB=20

# ── Chapa Payment Gateway ─────────────────────────────
# Get from: https://dashboard.chapa.co → Settings → API Keys
CHAPA_SECRET_KEY=CHASECK_TEST-your_chapa_secret_key
CHAPA_PUBLIC_KEY=CHAPUBK_TEST-your_chapa_public_key
CHAPA_WEBHOOK_SECRET=your_chapa_webhook_secret
CHAPA_BASE_URL=https://api.chapa.co/v1

# ── App Base URL (for payment callbacks) ─────────────
APP_BASE_URL=http://localhost:5000

# ── Rate Limiting ─────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
